# QuoteGif environment variables
# Copy to .env in this directory (or ~/.config/quotegif/.env) and fill in your values.
# Variables here are loaded automatically via python-dotenv; they will NOT override
# variables already set in your shell environment.
#
# Alternatively you can point to a specific .env file:
#   QUOTEGIF_DOTENV=/path/to/your.env

# ── API keys ──────────────────────────────────────────────────────────────────

# OpenAI (required when provider=openai)
OPENAI_API_KEY=sk-...

# Anthropic (required when provider=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Tavily web search — used by the Anthropic provider
TAVILY_API_KEY=tvly-...

# ── Provider selection ────────────────────────────────────────────────────────

# Which LLM provider to use: openai | anthropic | ollama
# QUOTEGIF_PROVIDER=openai

# Per-provider model overrides
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# OLLAMA_MODEL=llama3.1
# OLLAMA_HOST=http://localhost:11434

# ── Media library ─────────────────────────────────────────────────────────────

# OS-path-separator-joined list of folders to scan (`;` on Windows, `:` on Unix)
# QUOTEGIF_MEDIA_FOLDERS=D:\Videos\TV;D:\Videos\Movies

# Where to write output GIFs (default: ~/quotegifs)
# QUOTEGIF_OUTPUT_DIR=D:\quotegifs

# ── Clip padding ──────────────────────────────────────────────────────────────

# QUOTEGIF_PAD_BEFORE=1.5
# QUOTEGIF_PAD_AFTER=2.5
# QUOTEGIF_MAX_DURATION=12

# ── GIF settings ─────────────────────────────────────────────────────────────

# QUOTEGIF_GIF_FPS=12
# QUOTEGIF_GIF_WIDTH=480

# ── Whisper transcription fallback ───────────────────────────────────────────

# QUOTEGIF_WHISPER_ENABLED=true
# QUOTEGIF_WHISPER_MODEL=base
# QUOTEGIF_WHISPER_DEVICE=auto

# ── Paths ─────────────────────────────────────────────────────────────────────

# Override the TOML config file location
# QUOTEGIF_CONFIG=D:\workspace\quotegif\config.toml

# Override the .env file location (useful for CI/containers)
# QUOTEGIF_DOTENV=/run/secrets/quotegif.env

# ── Docker Compose ────────────────────────────────────────────────────────────
# Volume paths are configured directly in docker-compose.yml under the
# `volumes:` section — no env vars needed for that.
# API keys above are all that docker-compose needs from this file.
