# QuoteGif environment variables
# Copy to .env in this directory and fill in your values.
# .env is gitignored — nothing here gets committed.
#
# Variables are loaded automatically; they will NOT override values
# already set in your shell environment.

# ── Docker Compose: host paths (required when using Docker) ───────────────────
# These tell docker-compose where to find your files on the HOST machine.
# Inside the container the app always sees /media and /output — don't change those.

QUOTEGIF_HOST_MEDIA=/path/to/your/video/library
QUOTEGIF_HOST_OUTPUT=/path/to/where/gifs/are/saved

# Web UI bind address on the host (use 0.0.0.0 for LAN access)
# QUOTEGIF_WEB_BIND=127.0.0.1
# QUOTEGIF_WEB_PORT=8765

# Web login (bootstrap first user when database is empty)
# QUOTEGIF_WEB_USERNAME=jamus
# QUOTEGIF_WEB_PASSWORD=change-me
# QUOTEGIF_WEB_SECRET=long-random-string-for-session-cookies

# ── API keys ──────────────────────────────────────────────────────────────────

# OpenAI (required when provider=openai)
OPENAI_API_KEY=sk-...

# Anthropic (required when provider=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Tavily web search — used by the Anthropic provider
TAVILY_API_KEY=tvly-...

# ── Provider selection ────────────────────────────────────────────────────────

# Which LLM provider to use: openai | anthropic | ollama
# QUOTEGIF_PROVIDER=openai

# Per-provider model overrides (no quotes needed, even for names with dots/dashes)
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# OLLAMA_MODEL=llama3.1
# OLLAMA_HOST=http://localhost:11434

# ── Media library (only needed when running WITHOUT Docker) ───────────────────
# When using Docker, the paths below are ignored — Docker mounts /media and
# /output from QUOTEGIF_HOST_MEDIA and QUOTEGIF_HOST_OUTPUT above instead.
#
# If running the tool directly on your machine (no Docker), uncomment and set:
# QUOTEGIF_MEDIA_FOLDERS=/path/to/TV;/path/to/Movies   # semicolon on Windows, colon on Unix
# QUOTEGIF_OUTPUT_DIR=/path/to/output

# ── Clip padding ──────────────────────────────────────────────────────────────

# QUOTEGIF_PAD_BEFORE=1.5
# QUOTEGIF_PAD_AFTER=2.5
# QUOTEGIF_MAX_DURATION=12

# ── GIF settings ─────────────────────────────────────────────────────────────

# QUOTEGIF_GIF_FPS=12
# QUOTEGIF_GIF_WIDTH=480

# ── Whisper transcription fallback ───────────────────────────────────────────

# QUOTEGIF_WHISPER_ENABLED=true
# QUOTEGIF_WHISPER_MODEL=base
# QUOTEGIF_WHISPER_DEVICE=auto

# ── Misc paths ────────────────────────────────────────────────────────────────

# QUOTEGIF_CONFIG=/path/to/config.toml   Override TOML config location
# QUOTEGIF_DOTENV=/path/to/.env          Override .env file location
