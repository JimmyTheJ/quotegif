#!/usr/bin/env sh
# Wrapper to run quotegif via Docker Compose without typing the full command.
#
# Usage (from the project directory):
#   ./qg find "no soup for you"
#   ./qg compare "that's what she said" --providers openai,ollama
#   ./qg index
#   ./qg config
#
# To use it from anywhere, symlink or copy it onto your PATH:
#   ln -s "$PWD/qg" /usr/local/bin/quotegif

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
exec docker compose -f "$SCRIPT_DIR/docker-compose.yml" run --rm quotegif "$@"
